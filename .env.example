# Google Gemini API Key (required)
# Get yours at: https://aistudio.google.com/app/apikey
#
# 1. Copy this file:  cp .env.example .env
# 2. Replace the placeholder below with your real key.
# 3. Never commit the .env file — it is already in .gitignore.
GEMINI_API_KEY=your_api_key_here

# Gemini model for voice (optional override).
# Change this if the default model is deprecated or you want a different one.
# See https://ai.google.dev/gemini-api/docs/models for available models.
# GEMINI_MODEL=models/gemini-2.5-flash-preview-native-audio
