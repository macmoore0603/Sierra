# Google Gemini API Key (required)
# Get yours here: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# ---------- Sierra Router (optional) ----------
# Override the HuggingFace LoRA adapter repo for the on-device router.
# SIERRA_ROUTER_ADAPTER=Mac7Moore/ada_model
# SIERRA_ROUTER_BASE_MODEL=google/functiongemma-270m-it
# SIERRA_ROUTER_CACHE=~/.cache/sierra/router
# Confidence threshold below which the router falls back to Gemini.
# SIERRA_ROUTER_THRESHOLD=0.55

# ---------- Logging (optional) ----------
# Set the log level for Sierra's backend (DEBUG, INFO, WARNING, ERROR).
# SIERRA_LOG_LEVEL=INFO
