# Google Gemini API Key (required for voice & intelligence)
# Get yours at: https://aistudio.google.com/app/apikey
#
# 1. Copy this file:  cp .env.example .env
# 2. Replace the placeholder below with your real key.
# 3. Never commit the .env file — it is already in .gitignore.
GEMINI_API_KEY=your_api_key_here

# Gemini model for voice (optional override)
# Change this if the default model is deprecated or you want a different one.
# See https://ai.google.dev/gemini-api/docs/models for available models.
# GEMINI_MODEL=models/gemini-2.5-flash-native-audio-latest

# =============================================================================
# FUTURE PERSONAL INTEGRATIONS (placeholders for upcoming features)
# These will enable deep access to your ecosystem with built-in safety confirmations.
# =============================================================================

# Google Calendar & Gmail (for scheduling, email summaries, proactive reminders)
# GOOGLE_CLIENT_ID=your_client_id
# GOOGLE_CLIENT_SECRET=your_client_secret
# GOOGLE_REFRESH_TOKEN=your_refresh_token (or use OAuth flow)

# GitHub Integration (repo management, issue tracking, code assistance)
# GITHUB_TOKEN=ghp_your_personal_access_token

# Local / Other APIs
# NOTION_TOKEN=secret_...
# LINEAR_API_KEY=...

# Location / Context (for proactive, context-aware behavior)
# USER_LOCATION_LAT=...
# USER_LOCATION_LON=...

# Safety / Confirmation settings can also live here or in settings.json
# (Currently managed in settings.json for tool_permissions)
